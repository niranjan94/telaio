  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@daveyplate/better-auth-ui": "^3.0.0",
    "@parcel/watcher": "^2.5.6",
    "@testcontainers/postgresql": "^11.12.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.10.13",
    "@types/pg": "^8.0.0",
    "@types/react": "^19.0.0",
    "better-auth": "^1.5.0",
    "concurrently": "^9.2.1",
    "postgres-array": "^3.0.4",
    "react": "^19.2.4",
    "testcontainers": "^11.12.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
